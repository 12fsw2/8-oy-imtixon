generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  SELLER
}

enum SaleStatus {
  PAID
  PARTIAL
  UNPAID
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

model Company {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  categories         Category[]
  products           Product[]
  customers          Customer[]
  sales              Sale[]
  payments           Payment[]
  debts              Debt[]
  inventoryMovements InventoryMovement[]

  @@index([name])
}

model User {
  id        String    @id @default(cuid())
  companyId String
  firstName String
  lastName  String
  phone     String    @unique
  password  String
  role      Role      @default(SELLER)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales              Sale[]
  refreshTokens      RefreshToken[]
  inventoryMovements InventoryMovement[]

  @@index([companyId])
  @@index([phone])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id        String    @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([companyId])
}

model Product {
  id            String    @id @default(cuid())
  companyId     String
  categoryId    String?
  name          String
  sku           String?
  barcode       String?
  purchasePrice Decimal   @db.Decimal(12, 2)
  salePrice     Decimal   @db.Decimal(12, 2)
  stock         Int       @default(0)
  minStock      Int       @default(0)
  unit          String    @default("dona")
  description   String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id])
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([categoryId])
}

model Customer {
  id        String    @id @default(cuid())
  companyId String
  fullName  String
  phone     String?
  address   String?
  totalDebt Decimal   @default(0) @db.Decimal(12, 2)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales   Sale[]
  debts   Debt[]

  @@index([companyId])
  @@index([phone])
}

model Sale {
  id          String     @id @default(cuid())
  companyId   String
  customerId  String?
  userId      String
  status      SaleStatus @default(PAID)
  totalAmount Decimal    @db.Decimal(12, 2)
  paidAmount  Decimal    @default(0) @db.Decimal(12, 2)
  debtAmount  Decimal    @default(0) @db.Decimal(12, 2)
  note        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  items    SaleItem[]
  payments Payment[]
  debt     Debt?

  @@index([companyId])
  @@index([customerId])
  @@index([createdAt])
}

model SaleItem {
  id         String  @id @default(cuid())
  saleId     String
  productId  String
  quantity   Int
  price      Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(cuid())
  companyId String
  saleId    String?
  debtId    String?
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(CASH)
  note      String?
  createdAt DateTime      @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale    Sale?   @relation(fields: [saleId], references: [id])
  debt    Debt?   @relation(fields: [debtId], references: [id])

  @@index([companyId])
  @@index([saleId])
  @@index([debtId])
}

model Debt {
  id          String    @id @default(cuid())
  companyId   String
  customerId  String
  saleId      String?   @unique
  totalAmount Decimal   @db.Decimal(12, 2)
  paidAmount  Decimal   @default(0) @db.Decimal(12, 2)
  remaining   Decimal   @db.Decimal(12, 2)
  dueDate     DateTime?
  isPaid      Boolean   @default(false)
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id])
  sale     Sale?     @relation(fields: [saleId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@index([customerId])
}

model InventoryMovement {
  id          String       @id @default(cuid())
  companyId   String
  productId   String
  userId      String
  type        MovementType
  quantity    Int
  beforeStock Int
  afterStock  Int
  note        String?
  createdAt   DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([createdAt])
}
